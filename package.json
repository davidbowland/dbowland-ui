{
  "name": "dbowland-ui",
  "version": "1.68.0",
  "private": true,
  "description": "dbowland.com nextjs project",
  "author": "David Bowland",
  "engines": {
    "node": "^24.0.0"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidbowland/dbowland-ui.git"
  },
  "bugs": {
    "url": "https://github.com/davidbowland/dbowland-ui/issues"
  },
  "homepage": "https://github.com/davidbowland/dbowland-ui#readme",
  "scripts": {
    "build": "npm run clean && next build",
    "postbuild": "next-export-optimize-images && next-sitemap",
    "clean": "rm -rf .next coverage out && npm ci --legacy-peer-deps",
    "start": "next dev",
    "serve": "next build && npx serve out",
    "test": "jest --colors",
    "lint": "prettier --write . && eslint --fix .",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "update": "npx update-browserslist-db@latest && ncu --doctor --target minor --upgrade && npm audit fix --audit-level=none && npm run test && npm dedupe"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "husky": "^9.1.7",
    "next": "^14.2.35",
    "next-export-optimize-images": "^4.7.0",
    "next-sitemap": "^4.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^18.3.1",
    "sass": "^1.98.0",
    "styled-components": "^5.3.11",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/styled-components": "^5.1.36",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-react": "^7.37.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^13.3.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "^18.3.1",
    "ts-node": "^10.9.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write --ignore-unknown",
      "eslint --fix",
      "jest --colors --findRelatedTests --coverageThreshold '{}' --passWithNoTests"
    ],
    "**/*": [
      "prettier --write --ignore-unknown"
    ]
  }
}

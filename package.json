{
  "name": "dbowland-ui",
  "version": "1.79.0",
  "private": true,
  "description": "dbowland.com nextjs project",
  "author": "David Bowland",
  "engines": {
    "node": "^24.0.0"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidbowland/dbowland-ui.git"
  },
  "bugs": {
    "url": "https://github.com/davidbowland/dbowland-ui/issues"
  },
  "homepage": "https://github.com/davidbowland/dbowland-ui#readme",
  "scripts": {
    "build": "npm run clean && next build --webpack",
    "clean": "rm -rf .next coverage out && npm ci",
    "generate-resume": "ts-node scripts/generate-resume-pdf.ts",
    "lint": "prettier --write . && eslint --fix .",
    "postbuild": "next-export-optimize-images && next-sitemap && npm run generate-resume",
    "prepare": "husky",
    "serve": "next build --webpack && npx serve out",
    "start": "next dev --webpack",
    "test": "jest --colors",
    "typecheck": "tsc --noEmit",
    "update": "npx update-browserslist-db@latest && ncu --doctor --target minor --upgrade && npm audit fix --audit-level=none && npm run test && npm dedupe"
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@fontsource/pinyon-script": "^5.2.8",
    "@heroui/react": "^3.2.2",
    "framer-motion": "^12.42.2",
    "husky": "^9.1.7",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-export-optimize-images": "^4.7.0",
    "next-sitemap": "^4.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "sass": "^1.101.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-react": "^7.37.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^13.3.0",
    "prettier": "^3.9.5",
    "puppeteer": "^24.43.1",
    "react-test-renderer": "^19.2.7",
    "ts-node": "^10.9.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write --ignore-unknown",
      "eslint --fix",
      "jest --colors --findRelatedTests --coverageThreshold '{}' --passWithNoTests"
    ],
    "**/*": [
      "prettier --write --ignore-unknown"
    ]
  }
}
